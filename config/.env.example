# Variables d'environnement attendues (sans valeurs réelles)

DATABASE_URI=postgresql://user:password@host:5432/dbname

# Clé API mcpo (proxy MCP -> OpenAPI) — une par serveur, ou la même partout pour le prototype.
# Doit correspondre à la clé Bearer configurée côté Open WebUI (Intégrations > Gérer les serveurs d'outils).
MCPO_API_KEY_QGIS=change-me
MCPO_API_KEY_POSTGRES=change-me
