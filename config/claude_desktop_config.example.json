{
  "mcpServers": {
    "mcp-qgis": {
      "command": "python",
      "args": ["-m", "mcp_qgis"],
      "env": {
        "QGIS_PROJECT_PATH": "REPLACE_ME"
      }
    },
    "mcp-filesystem": {
      "command": "node",
      "args": ["servers/mcp-filesystem/src/index.js"],
      "env": {
        "ALLOWED_ROOT": "REPLACE_ME"
      }
    },
    "mcp-postgres": {
      "command": "python",
      "args": ["-m", "mcp_postgres"],
      "env": {
        "DATABASE_URL": "REPLACE_ME"
      }
    }
  }
}
